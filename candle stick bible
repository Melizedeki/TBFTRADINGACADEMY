//--- Include Trade Library explicitly for execution safety
#include <Trade\Trade.mqh>
CTrade trade;

//--- Input Parameters
input group "--- Candle Range Theory (CRT) ---"
input ENUM_TIMEFRAMES InpHTFTimeframe  = PERIOD_H4;     // Higher Time Frame for Dealing Range
input int             InpRangeLookback = 1;             // Number of HTF candles defining the CRT Anchor
input double          InpPremiumZone   = 0.75;          // Premium Threshold (>0.75)
input double          InpDiscountZone  = 0.25;          // Discount Threshold (<0.25)

input group "--- Killzone Session Filter ---"
input bool            InpUseSessionFilter = true;       // Trade only during institutional hours
input string          InpSessionStart     = "08:00";    // Session Execution Start (Server Time)
input string          InpSessionEnd       = "18:00";    // Session Execution End (Server Time)

input group "--- Risk & Trade Management ---"
input double          InpLotSize          = 0.10;       // Execution Lot Size
input int             InpStopLossPips     = 30;         // Stop Loss distance in Pips
input int             InpTakeProfitPips   = 60;         // Take Profit distance in Pips
input ulong           InpMagicNumber      = 882211;     // Magic Identification Number

//--- Global Tracking States
double crt_high_boundary = 0.0;
double crt_low_boundary  = 0.0;
datetime last_processed_bar;

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   Print("[SYSTEM] CRT & Candle Bible Professional Engine Online.");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert deinitialization function                                 |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   Print("[SYSTEM] Engine shutting down clean. Mode: ", reason);
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   // Check structural formation constraints to prevent duplicate processing on the same candle
   datetime current_bar_time = iTime(_Symbol, _Period, 0);
   if(current_bar_time == last_processed_bar) return;
   
   // Session Filtering System
   if(InpUseSessionFilter && !IsInsideSession()) return;

   // 1. ANCHOR HIGHER TIMEFRAME DEALING RANGE (CRT RULE)
   int htf_highest_idx = iHighest(_Symbol, InpHTFTimeframe, MODE_HIGH, InpRangeLookback, 1);
   int htf_lowest_idx  = iLowest(_Symbol, InpHTFTimeframe, MODE_LOW, InpRangeLookback, 1);
   
   if(htf_highest_idx < 0 || htf_lowest_idx < 0) return;
   
   crt_high_boundary = iHigh(_Symbol, InpHTFTimeframe, htf_highest_idx);
   crt_low_boundary  = iLow(_Symbol, InpHTFTimeframe, htf_lowest_idx);
   double total_range = crt_high_boundary - crt_low_boundary;
   
   if(total_range <= 0) return;

   // Mathematical Equilibrium / Premium / Discount Matrices
   double premium_threshold  = crt_low_boundary + (total_range * InpPremiumZone);
   double discount_threshold = crt_low_boundary + (total_range * InpDiscountZone);

   // 2. CURRENT LOWER TIMEFRAME PRICE MATRICES (EXECUTION LEVEL)
   double open1  = iOpen(_Symbol, _Period, 1);
   double high1  = iHigh(_Symbol, _Period, 1);
   double low1   = iLow(_Symbol, _Period, 1);
   double close1 = iClose(_Symbol, _Period, 1);
   
   double open2  = iOpen(_Symbol, _Period, 2);
   double close2 = iClose(_Symbol, _Period, 2);

   double body_size1  = MathAbs(close1 - open1);
   double lower_wick1 = MathMin(open1, close1) - low1;
   double upper_wick1 = high1 - MathMax(open1, close1);

   // Avoid zero division on flat candles
   if(body_size1 <= 0) body_size1 = _Point;

   // 3. EXECUTING CANDLE BIBLE PATTERN RULES INSIDE LIQUIDITY POOLS

   // --- BULLISH BIAS CRITERIA (Liquidity Grab below CRT Low or inside Discount Pool)
   bool is_discount_grab = (low1 < crt_low_boundary) || (close1 <= discount_threshold);
   
   if(is_discount_grab && PositionsTotal() == 0)
   {
      // Candle Bible Structural Patterns
      bool engulfing_bull = (close1 > open1) && (close2 < open2) && (close1 >= open2) && (open1 <= close2);
      bool pinbar_bull    = (lower_wick1 >= body_size1 * 2.0) && (upper_wick1 <= body_size1 * 0.5);
      
      if(engulfing_bull || pinbar_bull)
      {
         string signature = engulfing_bull ? "Bullish Engulfing" : "Bullish Pinbar Pin";
         Print("[CRT ALIGNMENT] Purge detected in Discount. Signature: ", signature);
         ExecuteOrder(ORDER_TYPE_BUY);
         last_processed_bar = current_bar_time;
         return;
      }
   }

   // --- BEARISH BIAS CRITERIA (Liquidity Grab above CRT High or inside Premium Pool)
   bool is_premium_grab = (high1 > crt_high_boundary) || (close1 >= premium_threshold);
   
   if(is_premium_grab && PositionsTotal() == 0)
   {
      // Candle Bible Structural Patterns
      bool engulfing_bear = (close1 < open1) && (close2 > open2) && (close1 <= open2) && (open1 >= close2);
      bool pinbar_bear    = (upper_wick1 >= body_size1 * 2.0) && (lower_wick1 <= body_size1 * 0.5);
      
      if(engulfing_bear || pinbar_bear)
      {
         string signature = engulfing_bear ? "Bearish Engulfing" : "Bearish Pinbar Pin";
         Print("[CRT ALIGNMENT] Purge detected in Premium. Signature: ", signature);
         ExecuteOrder(ORDER_TYPE_SELL);
         last_processed_bar = current_bar_time;
         return;
      }
   }
}

//+------------------------------------------------------------------+
//| Verification Module: Session Killzone Validity                    |
//+------------------------------------------------------------------+
bool IsInsideSession()
{
   datetime current = TimeCurrent();
   string curr_date = TimeToString(current, TIME_DATE);
   
   datetime start_time = StringToTime(curr_date + " " + InpSessionStart);
   datetime end_time   = StringToTime(curr_date + " " + InpSessionEnd);
   
   return (current >= start_time && current <= end_time);
}

//+------------------------------------------------------------------+
//| Execution Module: Direct Pipeline to MT5 Order Engine            |
//+------------------------------------------------------------------+
void ExecuteOrder(ENUM_ORDER_TYPE type)
{
   double price;
   double sl = 0.0;
   double tp = 0.0;
   
   int multiplier = (_Digits == 3 || _Digits == 5) ? 10 : 1;
   double point_size = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   
   double sl_distance = InpStopLossPips * multiplier * point_size;
   double tp_distance = InpTakeProfitPips * multiplier * point_size;

   if(type == ORDER_TYPE_BUY)
   {
      price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      sl = price - sl_distance;
      tp = price + tp_distance;
      
      trade.Buy(InpLotSize, _Symbol, price, sl, tp, "CRT Pro Buy");
   }
   else if(type == ORDER_TYPE_SELL)
   {
      price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      sl = price + sl_distance;
      tp = price - tp_distance;
      
      trade.Sell(InpLotSize, _Symbol, price, sl, tp, "CRT Pro Sell");
   }
}//+------------------------------------------------------------------+
